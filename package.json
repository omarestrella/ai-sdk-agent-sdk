{
  "name": "@omarestrella/ai-sdk-agent-sdk",
  "version": "1.0.0-beta.2",
  "description": "AI SDK provider for the Agent SDK for OpenCode",
  "homepage": "https://github.com/omarestrella/ai-sdk-agent-sdk",
  "keywords": [
    "agent-sdk",
    "ai-sdk",
    "anthropic",
    "claude",
    "opencode"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/omarestrella/ai-sdk-agent-sdk.git"
  },
  "files": [
    "dist",
    "src",
    "README.md"
  ],
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      }
    }
  },
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "prepublishOnly": "rm -rf dist && tsc -p tsconfig.build.json",
    "lint": "oxlint",
    "lint:fix": "oxlint --fix",
    "fmt": "oxfmt",
    "fmt:check": "oxfmt --check",
    "test": "bun test"
  },
  "dependencies": {
    "@ai-sdk/provider": "^2.0.0",
    "@ai-sdk/provider-utils": "^3.0.0",
    "@anthropic-ai/claude-agent-sdk": ">=0.2.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@anthropic-ai/sdk": "^0.72.1",
    "@types/consola": "^2.2.8",
    "@types/bun": "^1.3.8",
    "@types/node": "^25.1.0",
    "oxfmt": "^0.27.0",
    "oxlint": "^1.42.0",
    "typescript": "^5.0.0"
  },
  "peerDependencies": {
    "@anthropic-ai/claude-agent-sdk": ">=0.2.0",
    "consola": ""
  },
  "peerDependenciesMeta": {
    "consola": {
      "optional": true
    }
  },
  "engines": {
    "node": ">=18"
  }
}
